# Artymes — ARTY AI Employee
# Copy this to .env and fill in your keys

ANTHROPIC_API_KEY=your_anthropic_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here
OPENAI_API_KEY=your_openai_key_here

# ElevenLabs voice ID for ARTY (find in ElevenLabs dashboard)
ARTY_VOICE_ID=your_voice_id_here

# Optional: set to "true" to use push-to-talk instead of always-on mic
PUSH_TO_TALK=false

# Wake word for always-on mode (default: "hey arty")
WAKE_WORD=hey arty

# Memory
MEMORY_DB_PATH=./data/arty_memory.db
CHROMA_PATH=./data/chroma
